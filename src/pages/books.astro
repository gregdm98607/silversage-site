---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Books — Silver Sage Media"
        description="Browse the Silver Sage Books catalog — literary fiction and nonfiction rooted in the American West.">

  <section>
    <p class="section-label">Catalog</p>
    <h2>Silver Sage Books</h2>
    <p class="section-intro">Stories rooted in the American West — fiction and nonfiction built with care, published with pride.</p>

    <div class="grid-3">
      <div class="book-card">
        <div class="book-cover">[ TLC Cover Image ]</div>
        <div class="book-info">
          <h3>The Lund Covenant</h3>
          <p class="author">Greg Maxfield</p>
          <p>A novel of the contemporary American West — landscape, memory, and the ties that hold us to place.</p>
          <p style="margin-top:1rem;">
            <a href="#" class="btn btn-primary" style="padding:0.5rem 1.2rem;font-size:0.85rem;">Buy Now &rarr;</a>
          </p>
        </div>
      </div>

      <div class="book-card">
        <div class="book-cover">[ TUP Cover Image ]</div>
        <div class="book-info">
          <h3>The Unfolding Plot</h3>
          <p class="author">Greg Maxfield</p>
          <p>Currently serialized on Substack. Subscribe to the newsletter for book release updates.</p>
          <p style="margin-top:1rem;">
            <a href="https://gregmaxfield.substack.com" class="btn btn-outline" style="padding:0.5rem 1.2rem;font-size:0.85rem;">Read on Substack &rarr;</a>
          </p>
        </div>
      </div>

      <div class="book-card">
        <div class="book-cover">[ Future Title ]</div>
        <div class="book-info">
          <h3>Coming Soon</h3>
          <p class="author">Silver Sage Books</p>
          <p>More titles on the way. Subscribe to the newsletter for release announcements and early access.</p>
          <p style="margin-top:1rem;">
            <a href="/newsletter/" class="btn btn-outline" style="padding:0.5rem 1.2rem;font-size:0.85rem;">Get Notified &rarr;</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Distribution Info -->
  <section>
    <h2>Where to Buy</h2>
    <div class="about-text" style="max-width:750px;">
      <p>Silver Sage Books titles are distributed through IngramSpark and available at major online retailers including Amazon, Barnes &amp; Noble, and independent bookstores. We also plan to offer direct purchases through this site.</p>
      <p>For wholesale or bulk orders, please <a href="/contact/">contact us</a>.</p>
    </div>
  </section>

</Layout>
