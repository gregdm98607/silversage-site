---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Silver Sage Media"
        description="Get in touch with Silver Sage Media for business inquiries, publishing submissions, or collaboration proposals.">

  <section>
    <p class="section-label">Get in Touch</p>
    <h2>Contact Silver Sage Media</h2>

    <div class="contact-grid">
      <div class="contact-form">
        <label>Name</label>
        <input type="text" placeholder="Your name" />
        <label>Email</label>
        <input type="email" placeholder="your@email.com" />
        <label>Subject</label>
        <input type="text" placeholder="What's this about?" />
        <label>Message</label>
        <textarea placeholder="Tell us what you're thinking..."></textarea>
        <button class="btn btn-primary" style="margin-top:1.5rem;">Send Message</button>
      </div>

      <div class="contact-info">
        <h3>Other Ways to Reach Us</h3>
        <p><strong>Email:</strong> greg@silversagemedia.com</p>
        <p><strong>Location:</strong> Camas, Washington</p>
        <p><strong>Business inquiries:</strong> Publishing submissions, consulting requests, and partnership proposals are welcome.</p>
        <p style="margin-top:1.5rem;"><strong>Brand-specific sites:</strong></p>
        <p><a href="https://gregmaxfield.com">gregmaxfield.com</a> — Author site</p>
        <p><a href="https://operationgrannyfiles.com">operationgrannyfiles.com</a> — Operation Granny Files</p>
        <p><a href="https://conduital.com">conduital.com</a> — Conduital</p>
      </div>
    </div>
  </section>

</Layout>
