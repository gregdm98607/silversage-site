---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Newsletter — Silver Sage Media"
        description="Subscribe to The Silver Sage Dispatch — new book announcements, writing updates, genealogy discoveries, and reflections on the craft of storytelling.">

  <section style="max-width:650px;">
    <p class="section-label">Newsletter</p>
    <h2>The Silver Sage Dispatch</h2>
    <p class="section-intro">A periodic newsletter from Greg Maxfield and the Silver Sage team. New book announcements, behind-the-scenes writing updates, genealogy discoveries, and the occasional reflection on the craft of storytelling.</p>

    <div class="newsletter-box" style="margin-top:2rem;">
      <h3 style="margin-bottom:1rem;">What You'll Get</h3>
      <p class="sans">Early access to new releases and cover reveals. Writing process updates from active projects. Family history tips from Operation Granny Files. No spam — just stories and substance, a few times a month.</p>
      <div class="email-form" style="margin-top:1.5rem;">
        <input type="email" placeholder="your@email.com" />
        <button>Subscribe via Kit</button>
      </div>
      <p class="sans" style="font-size:0.8rem;margin-top:1rem;opacity:0.7;">Powered by ConvertKit (Kit). Unsubscribe anytime.</p>
    </div>
  </section>

</Layout>
