---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog — Silver Sage Media"
        description="Dispatches on writing, publishing, genealogy, and the work behind the work from Silver Sage Media.">

  <section>
    <p class="section-label">Blog</p>
    <h2>From the Desk</h2>
    <p class="section-intro">Dispatches on writing, publishing, genealogy, and the work behind the work.</p>

    <div class="grid-3">
      <div class="card blog-card">
        <p class="date">Coming Soon</p>
        <h3>Why Self-Publishing in 2026</h3>
        <p>The tools have changed, the stigma has faded, and the economics finally make sense. Here's what we've learned.</p>
      </div>
      <div class="card blog-card">
        <p class="date">Coming Soon</p>
        <h3>Building a Second Brain for Writers</h3>
        <p>How a PARA-structured digital archive keeps research organized and creativity flowing.</p>
      </div>
      <div class="card blog-card">
        <p class="date">Coming Soon</p>
        <h3>The Granny Files Method</h3>
        <p>A practical approach to family history that goes beyond names and dates.</p>
      </div>
    </div>
  </section>

  <!-- Cross-promo -->
  <section>
    <div class="about-text" style="max-width:750px;text-align:center;margin:0 auto;">
      <p>For serialized fiction and writing updates, visit <a href="https://gregmaxfield.substack.com">The Unfolding Plot on Substack</a>.</p>
    </div>
  </section>

</Layout>
